# Database Configuration
# Local development:
DATABASE_URL=mysql+pymysql://username:password@localhost:3306/database_name

# Railway deployment - use Railway's MySQL variables:
# DATABASE_URL=mysql+pymysql://${{MySQL.MYSQL_USER}}:${{MySQL.MYSQL_PASSWORD}}@${{MySQL.MYSQL_HOST}}:${{MySQL.MYSQL_PORT}}/${{MySQL.MYSQL_DATABASE}}

DATABASE_ECHO=True
DATABASE_POOL_PRE_PING=True
DATABASE_POOL_RECYCLE=3600

# JWT Authentication
# IMPORTANT: Generate a strong secret key for production!
# You can generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-a-strong-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Settings (comma-separated list of allowed origins)
# Add your frontend URL when deploying
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Application Settings
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=True

# Note: Railway automatically sets the PORT variable, which takes priority over APP_PORT
